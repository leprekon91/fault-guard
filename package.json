{
  "name": "circuit",
  "version": "0.1.0",
  "description": "A resilience layer for HTTP clients that adds retries, backoff, rate-limit handling, and circuit breakers.",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --out-dir dist",
    "clean": "rm -rf dist node_modules .turbo",
    "test": "vitest --run",
    "lint": "eslint --ext .ts src",
    "format": "prettier --write \"src/**/*.ts\" README.md"
  },
  "keywords": [
    "resilience",
    "retry",
    "backoff",
    "circuit-breaker",
    "rate-limit",
    "axios"
  ],
  "author": "",
  "license": "MIT",
  "peerDependencies": {
    "axios": "^0.21 || ^1.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "eslint": "^8.0.0",
    "prettier": "^2.0.0",
    "tsup": "^6.0.0",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0"
  }
}
