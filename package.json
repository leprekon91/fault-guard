{
  "name": "@leprekon-hub/fault-guard",
  "version": "0.3.0",
  "description": "A resilience layer for HTTP clients that adds retries, backoff, rate-limit handling, and circuit breakers.",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --out-dir dist",
    "clean": "rm -rf dist node_modules .turbo",
    "test": "vitest --run",
    "lint": "eslint --ext .ts src",
    "format": "prettier --write \"src/**/*.ts\" README.md",
    "prepare": "npm run build",
    "prepublishOnly": "npm test && npm run build",
    "release": "standard-version"
  },
  "keywords": [
    "resilience",
    "retry",
    "backoff",
    "circuit-breaker",
    "rate-limit",
    "axios"
  ],
  "author": "",
  "license": "MIT",
  "peerDependencies": {
    "axios": "^0.21 || ^1.0"
  },
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/leprekon91/fault-guard.git"
  },
  "bugs": {
    "url": "https://github.com/leprekon91/fault-guard/issues"
  },
  "homepage": "https://github.com/leprekon91/fault-guard#readme",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "eslint": "^8.0.0",
    "prettier": "^2.0.0",
    "tsup": "^6.0.0",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0",
    "standard-version": "^9.5.0"
  }
}
